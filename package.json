{
  "name": "teachme-node",
  "version": "1.0.0",
  "description": "Node.js backend implementation for TeachMe app - runs inside Android assets",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "npm run build:clean && npm run build:bundle",
    "build:clean": "rm -rf dist",
    "build:bundle": "esbuild src/index.js --bundle --platform=node --outfile=dist/bundle.js --minify",
    "build:android": "npm run build && cp dist/bundle.js ../android-app/app/src/main/assets/",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "migrate": "node database/migrations/run.js",
    "seed": "node database/seeds/run.js"
  },
  "keywords": [
    "teachme",
    "nodejs",
    "android",
    "offline-first",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
}
